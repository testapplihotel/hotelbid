# SerpApi - Google Hotels ($50/month, free tier: 100 searches/month)
# Sign up: https://serpapi.com/users/sign_up
SERPAPI_KEY=

# Browserless.io - Cloud browser for scraping (free tier: 1000 sessions/month)
# Sign up: https://www.browserless.io/sign-up
BROWSERLESS_KEY=

# SMTP for email notifications
# Option 1: Gmail — use App Password (https://myaccount.google.com/apppasswords)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx
#
# Option 2: Resend (free 100 emails/day) — sign up at https://resend.com
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_your_api_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Server
PORT=3000
